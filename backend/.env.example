# TradeSense Backend — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Application ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ────────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://tradesense_user:tradesense_pass@db:5432/tradesense

# ── Security ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_ME_WITH_A_32_CHAR_RANDOM_SECRET_KEY_DO_NOT_USE_THIS_IN_PROD
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ── File Upload ─────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_BYTES=52428800   # 50 MB

# ── Market Data ─────────────────────────────────────────────────────────────────
MARKET_DATA_CACHE_TTL_SECONDS=3600
